# Cadence — environment variable template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── Public (safe to expose to browser) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# New publishable key (replaces legacy NEXT_PUBLIC_SUPABASE_ANON_KEY)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Server-only (NEVER use NEXT_PUBLIC_ prefix for these) ───────────────────
# New secret key (replaces legacy SUPABASE_SERVICE_ROLE_KEY)
# Used for elevated-privilege server-side operations only.
SUPABASE_SECRET_KEY=

# JWKS endpoint for local asymmetric JWT verification without a round-trip.
# Format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Used by jose in middleware and Edge Functions as a fallback path.
SUPABASE_JWKS_URL=

# Resend — email API key for weekly summary emails (Phase 7)
RESEND_API_KEY=

# Cron secret — must match the x-cron-secret header sent by Vercel Cron / pg_cron
CRON_SECRET=
