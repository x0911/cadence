# Cadence — environment variable template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── Public (safe to expose to browser) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only (NEVER use NEXT_PUBLIC_ prefix for these) ───────────────────
# Supabase service role — for Edge Functions and server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=

# Resend — email API key for weekly summary emails (Phase 7)
RESEND_API_KEY=

# Cron secret — must match the x-cron-secret header sent by Vercel Cron / pg_cron
CRON_SECRET=
